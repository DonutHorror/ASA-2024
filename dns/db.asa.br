;
; BIND data file for local loopback interface
;
$ORIGIN gilson.asa.br.
$TTL	604800

@	IN	SOA	@ root (
			      1		; Serial
			 604800		; Refresh
			  86400		; Retry
			2419200		; Expire
			 604800 )	; Negative Cache TTL
;
@	IN	NS	ns
@	IN	A	192.168.1.188
	IN	MX	10	mail

ns		IN	A	192.168.1.188
www	IN		A	192.168.1.188
proxy	IN	CNAME	www
web		IN	CNAME	www
mail	IN	CNAME	www